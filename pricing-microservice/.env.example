# Copy to .env for local development (never commit real secrets).

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/arkadDB?retryWrites=true&w=majority
DB_NAME=arkadDB

# Flask pricing service (local)
PORT=5001

# FastAPI forecasting service (local) — use a different port if you run both:
# PORT=8001

# --- Backend (ARKAD_Mines_backend) env when microservices are on Render ---
# PRICING_API_URL=https://YOUR-PRICING-SERVICE.onrender.com
# FORECASTING_API_URL=https://YOUR-FORECASTING-SERVICE.onrender.com/api/forecast
