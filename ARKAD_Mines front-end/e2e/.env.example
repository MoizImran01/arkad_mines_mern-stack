# E2E environment variables.
# Copy this file to .env and fill in the values. Do not commit .env.

# Frontend URL (buyer app) – no trailing slash
E2E_BASE_URL=http://localhost:5173

# Buyer account (must have an order with outstanding balance, e.g. Rs 50,000)
E2E_BUYER_EMAIL=raahima@gmail.com
E2E_BUYER_PASSWORD=raahima03

# Order number for the test order (e.g. ORD-303552-506) with Rs 50,000 remaining
E2E_ORDER_NUMBER=ORD-303552-506

# T02 Document History empty state: buyer with NO orders or quotations (new account)
# E2E_T02_EMAIL=new-buyer@example.com
# E2E_T02_PASSWORD=password
# Or use a separate token for T02 only (buyer with no documents):
# E2E_T02_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: active JWT token – if set, tests skip login and CAPTCHA (use a valid buyer token)
# E2E_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: wait times in seconds (defaults: 10 and 15)
# E2E_IMPLICIT_WAIT=10
# E2E_EXPLICIT_WAIT=15

# Optional: path to payment proof image (default: e2e/assets/test-payment-proof.jpg)
# E2E_PAYMENT_PROOF_IMAGE=e2e/assets/test_payment_proof.png
